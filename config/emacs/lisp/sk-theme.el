  "Fallback Sky Night color tokens used when runtime theme state is absent.")

(defvar sk/theme nil
  "Runtime Sky theme tokens loaded from `sk/theme-runtime-file'.")

(defvar sk/theme-runtime-file
  (expand-file-name "theme/current/emacs-theme.el"
                    (or (getenv "XDG_CONFIG_HOME")
                        (expand-file-name "~/.config")))
  "Generated theme-select token file for clean Emacs.")

(defun sk/load-runtime-theme ()
  "Load generated theme-select tokens when available."
  (setq sk/theme nil)
  (when (file-readable-p sk/theme-runtime-file)
    (load-file sk/theme-runtime-file)))

(defun sk/theme-color (name)
  "Return Sky color token NAME."
  (alist-get name (append sk/theme sk/theme-colors)))

(deftheme sky-night "Sky Night theme for the clean Emacs experiment.")

